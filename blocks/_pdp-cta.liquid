{% assign bst = block.settings %}

<div class="product__cta mt-4 md:mt-0">
    {% if bst.select_flavors_flow %}
        <div class="product__cta-button w-full mt-4">
            <a :href="`/pages/offer?product-handle={{ product.handle }}&view=offer-2&minQty=${minQty}`" class="flex items-center justify-center gap-[1.2rem] text-[2rem] font-bold bg-[#21A600] border-[.2rem] h-[6rem] border-[#037C2B] hover:bg-[#037C2B] rounded-[1rem] text-white">
                {{ bst.cta_button_text }} 
                <span class="inline-flex items-center justify-center font-medium h-[2.4rem] bg-[#0D3063] text-white text-base rounded-full px-[1.2rem] gap-[.8rem]">
                    <span class="line-through text-[#D8D8D8]" x-text="formatMoney(price.compareAtPrice)"></span>

                    <span x-text="formatMoney(price.actualPrice)"></span>
                </span>

                <span class="ml-[.6rem]">
                    <svg width="17" height="17" viewBox="0 0 17 17" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12.672 7.70302L0.5 7.70302V9.70302H12.672L7.308 15.067L8.722 16.481L16.5 8.70302L8.722 0.925018L7.308 2.33902L12.672 7.70302Z" fill="white"/>
                    </svg>
                </span>
            </a>
        </div>
        {% else %}
            <div class="product__cta-button w-full mt-4">
                <button
                    type="button"
                    class="btn w-full btn-lg"
                    data-pdp-buy-now
                    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                >
                    {{ bst.cta_button_text }}
                </button>
            </div>
    {% endif %}
</div>

<script>
    if (!window.pdpBuyNowInitialized) {
        window.pdpBuyNowInitialized = true;

        document.addEventListener('click', async (event) => {
            const button = event.target.closest('[data-pdp-buy-now]');

            if (!button) return;

            const variantId = parseInt(button.dataset.variantId, 10);

            if (!variantId || button.disabled) return;

            button.disabled = true;
            button.classList.add('opacity-70', 'pointer-events-none');

            try {
                const response = await fetch(`${window.Shopify.routes.root}cart/add.js`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        items: [
                            {
                                id: variantId,
                                quantity: 1
                            }
                        ]
                    })
                });

                if (!response.ok) {
                    throw new Error('Failed to add product to cart');
                }

                window.location.href = `${window.Shopify.routes.root}checkout`;
            } catch (error) {
                console.error(error);
            } finally {
                button.disabled = false;
                button.classList.remove('opacity-70', 'pointer-events-none');
            }
        });
    }
</script>

{% schema %}
{
  "name": "CTA",
  "tag": null,
  "settings": [
    {
        "type": "header",
        "content": "CTA Button"
    },
    {
        "type": "text",
        "label": "CTA Button Text",
        "id": "cta_button_text",
        "default": "Choose Your Package"
    },
    {
        "type": "checkbox",
        "label": "Select Flavors Flow",
        "id": "select_flavors_flow",
        "default": false
    }
  ],
  "presets": [
    {
      "name": "CTA"
    }
  ]
}
{% endschema %}
