{% assign sst = section.settings %}
<footer class="footer text-base pt-[2rem] pb-[2rem] hidden" style="background-color: {{ sst.background_color }}; color: {{ sst.text_color }}" id="footer-gifts">
    <div class="container">
        <div class="border-b border-white pb-4 text-[1.1rem] leading-[1.3] mb-4">
            {{ sst.text_1 }}
        </div>

        <div class="flex flex-col gap-2 text-[1rem] leading-[1.2]">

            <ul class="footer__policies flex items-center gap-4">
                {%- if sst.footer_policy_menu != blank -%}
                    {%- for link in sst.footer_policy_menu.links -%}
                        <li>
                            <a href="{{ link.url }}">{{ link.title | escape }}</a>
                        </li>
                    {%- endfor -%}
                {%- else -%}
                    {%- for policy in shop.policies -%}
                        {%- if policy != blank -%}
                            <li>
                                <a href="{{ policy.url }}">{{ policy.title | escape }}</a>
                            </li>
                        {%- endif -%}
                    {%- endfor -%}
                {%- endif -%}
            </ul>

            <div class="footer__content-item]">
                {{ sst.copyright }}
            </div>
        </div>
    </div>
</footer>


{% schema %}
{
  "name": "Footer for Gifts",
  "settings": [
    {
      "type": "link_list",
      "label": "Footer menu 1",
      "id": "footer_menu_1"
    },
    {
      "type": "link_list",
      "label": "Footer menu 2",
      "id": "footer_menu_2"
    },
    {
      "type": "link_list",
      "label": "Footer policy menu",
      "id": "footer_policy_menu"
    },
    {
        "type": "color",
        "label": "Text color",
        "id": "background_color",
        "default": "#153164"
    },

    {
      "type": "color",
      "label": "Text color",
      "id": "text_color",
      "default": "#FFFFFF"
    },
    {
      "type": "richtext",
      "label": "Text 1",
      "id": "text_1"
    },
    {
      "type": "richtext",
      "label": "Text 2",
      "id": "text_2"
    },
    {
      "type": "richtext",
      "label": "Copyright",
      "id": "copyright"
    }
  ]
}
{% endschema %}
